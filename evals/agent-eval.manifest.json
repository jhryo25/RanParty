{
  "schemaVersion": 1,
  "name": "RanParty Agent 深度评测",
  "description": "使用离线假 Provider、协议烟测、源码契约和人工任务缺口共同评估 Agent，而不是只统计单元测试通过率。",
  "releaseGate": 80,
  "dimensions": [
    { "id": "task_completion", "label": "任务完成与正确性", "weight": 25 },
    { "id": "tool_use", "label": "工具使用与验证", "weight": 15 },
    { "id": "safety", "label": "安全与权限边界", "weight": 20 },
    { "id": "context_memory", "label": "上下文与记忆", "weight": 15 },
    { "id": "collaboration", "label": "多 Agent 与能力路由", "weight": 10 },
    { "id": "robustness", "label": "恢复性与兼容性", "weight": 10 },
    { "id": "observability_efficiency", "label": "可观测性与效率", "weight": 5 }
  ],
  "preflight": [
    {
      "id": "backend-build",
      "title": "构建评测后端",
      "type": "command",
      "command": "dotnet",
      "args": ["build", "backend/RanParty.Backend.csproj", "--no-restore"]
    }
  ],
  "checks": [
    { "id": "plan-mode", "title": "Plan 模式不提前执行", "dimension": "task_completion", "points": 4, "type": "command", "command": "node", "args": ["tests/plan-mode-smoke.mjs"] },
    { "id": "post-write-verification", "title": "文件修改后强制验证", "dimension": "task_completion", "points": 5, "type": "command", "command": "node", "args": ["tests/post-write-verification-smoke.mjs"] },
    { "id": "loop-budget", "title": "工具循环预算耗尽后收敛", "dimension": "task_completion", "points": 4, "type": "command", "command": "node", "args": ["tests/tool-loop-budget-smoke.mjs"] },
    {
      "id": "evidence-ledger",
      "title": "需求到证据的完成账本",
      "dimension": "task_completion",
      "points": 5,
      "type": "source",
      "path": "backend/BackendHost.cs",
      "requires": ["requirement.{0,40}evidence", "verification_state"],
      "gap": "当前只记录本轮是否发生过验证，不能证明验证证据覆盖了哪项需求或哪次修改。"
    },
    {
      "id": "semantic-repo-benchmark",
      "title": "真实仓库任务的语义正确性基准",
      "dimension": "task_completion",
      "points": 7,
      "type": "manual",
      "gap": "尚无 golden patch、隐藏测试或 LLM judge 任务集，无法衡量最终方案是否真正解决用户问题。"
    },

    { "id": "core-tool-runtime", "title": "核心工具运行时契约", "dimension": "tool_use", "points": 4, "type": "command", "command": "dotnet", "args": ["run", "--project", "tests/CoreRuntimeSmoke/CoreRuntimeSmoke.csproj", "--no-restore"] },
    { "id": "mcp-connector", "title": "MCP 工具发现与调用", "dimension": "tool_use", "points": 3, "type": "command", "command": "node", "args": ["tests/mcp-connector-smoke.mjs"] },
    { "id": "tooling-model-switch", "title": "工具模型切换保持轨迹", "dimension": "tool_use", "points": 3, "type": "command", "command": "node", "args": ["tests/tooling-model-switch-smoke.mjs"] },
    { "id": "loop-guard", "title": "重复工具调用拦截", "dimension": "tool_use", "points": 3, "type": "command", "command": "node", "args": ["tests/tool-loop-guard-smoke.mjs"] },
    {
      "id": "shell-change-evidence",
      "title": "Shell 修改路径与验证类型结构化返回",
      "dimension": "tool_use",
      "points": 2,
      "type": "source",
      "path": "backend/BackendHost.cs",
      "requires": ["changed_paths", "verification_kind"],
      "gap": "Shell 修改仍依赖命令文本启发式识别，无法把具体变更路径与验证证据可靠关联。"
    },

    { "id": "subagent-approval", "title": "子 Agent 继承审批边界", "dimension": "safety", "points": 5, "type": "command", "command": "node", "args": ["tests/subagent-approval-smoke.mjs"] },
    { "id": "tool-output-approval", "title": "工具产物跨轮次隔离与审批", "dimension": "safety", "points": 5, "type": "command", "command": "node", "args": ["tests/tool-output-approval-smoke.mjs"] },
    { "id": "skill-capability", "title": "Skill 工具 allowlist", "dimension": "safety", "points": 3, "type": "command", "command": "node", "args": ["tests/skill-capability-smoke.mjs"] },
    { "id": "skill-implicit-capability", "title": "隐式 Skill 权限约束", "dimension": "safety", "points": 3, "type": "command", "command": "node", "args": ["tests/skill-implicit-capability-smoke.mjs"] },
    {
      "id": "adversarial-safety-corpus",
      "title": "提示注入与越权对抗任务集",
      "dimension": "safety",
      "points": 4,
      "type": "manual",
      "gap": "已有审批契约，但缺少附件注入、恶意 Skill、MCP 返回污染和跨工作区读取的系统化红队语料。"
    },

    { "id": "context-compaction", "title": "压缩保留最新工作集", "dimension": "context_memory", "points": 4, "type": "command", "command": "node", "args": ["tests/context-compaction-smoke.mjs"] },
    { "id": "context-auto-compaction", "title": "上下文阈值自动压缩", "dimension": "context_memory", "points": 4, "type": "command", "command": "node", "args": ["tests/context-auto-compaction-smoke.mjs"] },
    { "id": "context-recompaction", "title": "二次压缩不漂移", "dimension": "context_memory", "points": 4, "type": "command", "command": "node", "args": ["tests/context-recompaction-smoke.mjs"] },
    { "id": "knowledge-growth", "title": "长期成长记录读写", "dimension": "context_memory", "points": 3, "type": "command", "command": "node", "args": ["tests/knowledge-growth-smoke.mjs"] },

    { "id": "subagent-delegation", "title": "子 Agent 委派与结果回传", "dimension": "collaboration", "points": 4, "type": "command", "command": "node", "args": ["tests/subagent-delegation-smoke.mjs"] },
    { "id": "vision-routing", "title": "视觉能力自动路由", "dimension": "collaboration", "points": 3, "type": "command", "command": "node", "args": ["tests/vision-routing-smoke.mjs"] },
    {
      "id": "team-parallel-enforcement",
      "title": "专家团队并发上限由运行时强制",
      "dimension": "collaboration",
      "points": 3,
      "type": "command",
      "command": "node",
      "args": ["tests/subagent-parallel-smoke.mjs"]
    },

    { "id": "chat-idempotency", "title": "重复发送幂等", "dimension": "robustness", "points": 3, "type": "command", "command": "node", "args": ["tests/chat-idempotency-smoke.mjs"] },
    { "id": "provider-protocol", "title": "多 Provider 协议兼容", "dimension": "robustness", "points": 2, "type": "command", "command": "node", "args": ["tests/provider-protocol-smoke.mjs"] },
    { "id": "session-delete-race", "title": "删除与运行竞态", "dimension": "robustness", "points": 2, "type": "command", "command": "node", "args": ["tests/session-delete-race-smoke.mjs"] },
    {
      "id": "provider-fallback",
      "title": "同一 Turn 的跨 Provider 自动恢复",
      "dimension": "robustness",
      "points": 3,
      "type": "source",
      "path": "backend/BackendHost.cs",
      "requires": ["fallbackProfile|fallback_profile", "turn.retrying.{0,500}profile"],
      "gap": "当前只对同一 Provider 重试三次，没有保留 Turn 轨迹切换备用 Profile 的机制。"
    },

    {
      "id": "terminal-status-taxonomy",
      "title": "完整、部分完成、预算耗尽等终态可区分",
      "dimension": "observability_efficiency",
      "points": 2,
      "type": "source",
      "path": "backend/BackendHost.cs",
      "requires": ["partial", "budget_exhausted", "terminal_status|terminalStatus"],
      "gap": "预算耗尽后的归纳仍会落为 completed，无法区分真正完成与部分完成。"
    },
    {
      "id": "turn-metrics",
      "title": "Turn 级迭代、工具、验证和错误指标",
      "dimension": "observability_efficiency",
      "points": 1.5,
      "type": "source",
      "path": "backend/BackendHost.cs",
      "requires": ["iteration_count", "tool_call_count", "last_successful_action", "last_error"],
      "gap": "内存中有循环计数，但没有持久化或事件化为可聚合指标。"
    },
    {
      "id": "trajectory-efficiency-benchmark",
      "title": "Token、时延、工具步数和重试成本基准",
      "dimension": "observability_efficiency",
      "points": 1.5,
      "type": "manual",
      "gap": "尚未记录任务级成本分布，也没有模型/Profile 之间的质量成本对比。"
    }
  ]
}
